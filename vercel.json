{
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/youtube/poll-playlist",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/youtube/fetch-transcripts",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/youtube/extract-knowledge",
      "schedule": "1-59/2 * * * *"
    },
    {
      "path": "/api/summaries/backfill?batch_size=10",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/meetings/process",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/anchors/score-daily",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/microsoft/sync",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/microsoft/fetch-transcripts",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/microsoft/extract-knowledge",
      "schedule": "5-55/10 * * * *"
    },
    {
      "path": "/api/microsoft/renew-subscriptions",
      "schedule": "0 0 */2 * *"
    },
    {
      "path": "/api/digest/generate-scheduled",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/skills/backfill?batch_size=8",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/skills/daily-cron",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/skills/rescore",
      "schedule": "0 2 * * 0"
    }
  ]
}
